  "homepage": "https://github.com/hecoococ/DeskAtom#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hecoococ/DeskAtom.git"
  },
  "bugs": {
    "url": "https://github.com/hecoococ/DeskAtom/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  }
