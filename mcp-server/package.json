{
  "name": "deskatom-mcp-server",
  "version": "2.7.0",
  "description": "Local stdio MCP server for DeskAtom task and group management.",
  "type": "module",
  "main": "mcpServer.js",
  "bin": {
    "deskatom-mcp-server": "mcpServer.js"
  },
  "scripts": {
    "start": "node mcpServer.js",
    "check": "node --check mcpServer.js && node --check taskStore.js && node --check aiService.js"
  },
  "files": [
    "mcpServer.js",
    "taskStore.js",
    "aiService.js",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "mcp-server",
    "deskatom",
    "todo",
    "tasks"
  ],
  "author": "DeskAtom",
