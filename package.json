{
  "name": "deskatom",
  "version": "2.6.2",
  "type": "module",
  "description": "DeskAtom - 现代化的任务管理桌面应用",
  "author": "DeskAtom",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"pnpm dev\" \"wait-on http://localhost:1420 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "pnpm build && cross-env USE_NPM=true CSC_IDENTITY_AUTO_DISCOVERY=false ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ electron-builder",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@alicloud/pop-core": "^1.8.0",
    "alibabacloud-nls": "^1.0.4",
    "vue": "^3.4.21",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/test-utils": "^2.4.4",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "happy-dom": "^13.6.2",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.6",
    "vitest": "^1.3.1",
    "wait-on": "^7.2.0"
  },
  "build": {
      "npmRebuild": false,
  "nodeGypRebuild": false,
  "buildDependenciesFromSource": false,
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "appId": "com.deskatom.app",
    "productName": "DeskAtom",
    "copyright": "Copyright © 2026 DeskAtom",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/@alicloud/**/*",
      "node_modules/httpx/**/*",
      "node_modules/debug/**/*",
      "node_modules/json-bigint/**/*",
      "node_modules/kitx/**/*",
      "node_modules/xml2js/**/*"
    ],
    "win": {
      "signAndEditExecutable": true,
      "icon": "build/icons/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DeskAtom",
      "installerIcon": "build/icons/icon.ico",
      "uninstallerIcon": "build/icons/icon.ico",
      "installerHeaderIcon": "build/icons/icon.ico",
      "installerLanguages": [
        "zh_CN",
        "en_US"
      ],
      "language": "2052"
    }
  }
}
