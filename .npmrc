# 国内镜像：加速 pnpm install
registry=https://registry.npmmirror.com

# Electron 正式包从镜像拉（electron-builder 打包时用），避免 GitHub 过慢
electron_mirror=https://npmmirror.com/mirrors/electron/

# NSIS、winCodeSign 等二进制走镜像： electron-builder 只认环境变量 ELECTRON_BUILDER_BINARIES_MIRROR，
# 已在 package.json 的 electron:build 里用 cross-env 写好；若在终端手动打包请自行 export / set 该变量。
